{
  "name": "luisardito-shop-backend",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "start:prod": "node dist/app.js",
    "dev": "nodemon app.js",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "migrate": "npx sequelize db:migrate",
    "migrate:status": "npx sequelize db:migrate:status",
    "migrate:undo": "npx sequelize db:migrate:undo",
    "migrate:undo:all": "npx sequelize db:migrate:undo:all",
    "seed": "npx sequelize db:seed:all",
    "seed:undo": "npx sequelize db:seed:undo:all",
    "setup-db": "npm run migrate && npm run seed",
    "reset-db": "npx sequelize db:migrate:undo:all && npm run setup-db",
    "docker:dev": "docker-compose up --build",
    "docker:dev:down": "docker-compose down",
    "docker:dev:logs": "docker-compose logs -f api",
    "docker:db": "docker-compose up db -d",
    "dev:local": "NODE_ENV=development nodemon app.js",
    "dev:setup": "docker-compose up db -d && npm run migrate && npm run seed",
    "dev:reset": "docker-compose down -v && docker-compose up db -d && sleep 10 && npm run migrate && npm run seed",
    "sync:migrations": "powershell -ExecutionPolicy Bypass -File scripts/sync-migrations.ps1",
    "reauth-bot": "node scripts/reauth-bot.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "presmoke": "npm run build",
    "smoke": "node -e \"const fs=require('fs');for(const d of ['dist/src/routes','dist/src/controllers'])fs.readdirSync(d).filter(f=>f.endsWith('.js')).forEach(f=>require('./'+d+'/'+f));console.log('boot-smoke OK');process.exit(0)\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.14.3",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.17.2",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.2",
    "ws": "^8.18.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.10",
    "prettier": "^3.9.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0"
  }
}
